# Port the manager dashboard listens on (host side)
MANAGER_PORT=5600

# Port range for n8n instances (each gets a dedicated host port)
# N8N_PORT_MIN=5601
# N8N_PORT_MAX=5699

# Admin login for the dashboard - CHANGE THESE before exposing this anywhere
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Random long string used to sign session cookies
SESSION_SECRET=please-change-this-session-secret

# The URL people will actually type in their browser to reach this server.
# Used to build each instance's WEBHOOK_URL / editor base URL.
# Examples: http://203.0.113.10:5600  or  https://automation.yourcompany.com
PUBLIC_BASE_URL=http://localhost:5600

# n8n image/tag to provision new instances from
N8N_IMAGE=n8nio/n8n:latest

TZ=Asia/Jakarta
