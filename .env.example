# Port the manager dashboard/proxy listens on (host side)
MANAGER_PORT=8000

# Admin login for the dashboard - CHANGE THESE before exposing this anywhere
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Random long string used to sign session cookies
SESSION_SECRET=please-change-this-session-secret

# The URL people will actually type in their browser to reach this server.
# Used to build each instance's WEBHOOK_URL / editor base URL so webhooks
# and the editor UI resolve correctly under /{code}/.
# Examples: http://203.0.113.10:8000  or  https://automation.yourcompany.com
PUBLIC_BASE_URL=http://localhost:8000

# n8n image/tag to provision new instances from
N8N_IMAGE=n8nio/n8n:latest

TZ=Asia/Jakarta
